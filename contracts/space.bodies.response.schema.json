{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rhino-gh-mcp/contracts/space.bodies.response",
  "title": "space.bodies response",
  "description": "Wire contract for the space.bodies listener command (spatial/PROTOCOL.md section 1). Any platform adapter (Rhino, Fusion, ...) must conform; validate with tools/validate-protocol.mjs.",
  "type": "object",
  "required": ["units", "upAxis", "sceneVersion", "bodies"],
  "properties": {
    "units": { "type": "string", "minLength": 1 },
    "upAxis": { "enum": ["z", "y"] },
    "sceneVersion": { "type": "integer", "minimum": 1 },
    "bodies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "kind", "bbox"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": ["string", "null"] },
          "source": { "enum": ["doc", "gh"] },
          "kind": { "enum": ["solid", "surface", "mesh", "curve", "other"] },
          "bbox": {
            "type": "object",
            "required": ["min", "max"],
            "properties": {
              "min": { "$ref": "#/definitions/vec3" },
              "max": { "$ref": "#/definitions/vec3" }
            }
          },
          "volume": { "type": ["number", "null"] },
          "area": { "type": ["number", "null"] },
          "centroid": { "anyOf": [{ "$ref": "#/definitions/vec3" }, { "type": "null" }] },
          "itemCount": { "type": ["integer", "null"] },
          "layer": { "type": ["string", "null"] }
        }
      }
    }
  },
  "definitions": {
    "vec3": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    }
  }
}
