{
  "name": "voronoi-panel",
  "description": "A 2D Voronoi pattern from random points inside a rectangle. Exposed params: width, depth, count.",
  "parameters": [
    { "key": "width", "label": "Width", "default": 50 },
    { "key": "depth", "label": "Depth", "default": 50 },
    { "key": "count", "label": "Point count", "default": 40 }
  ],
  "recipe": {
    "clear": false,
    "components": [
      { "key": "width", "type": "slider", "min": 5, "max": 200, "value": 50, "nickname": "Width" },
      { "key": "depth", "type": "slider", "min": 5, "max": 200, "value": 50, "nickname": "Depth" },
      { "key": "count", "type": "slider", "min": 3, "max": 300, "value": 40, "integer": true, "nickname": "Count" },
      { "key": "rect", "type": "d93100b6-d50b-40b2-831a-814659dc38e3", "note": "Rectangle (Curve>Primitive)" },
      { "key": "pop", "type": "e2d958e8-9f08-44f7-bf47-a684882d0b2a", "note": "Populate 2D (Vector>Grid)" },
      { "key": "voronoi", "type": "a4011be0-1c91-45bd-8280-17dd3a9f46f1", "note": "Voronoi (Mesh>Triangulation)" }
    ],
    "connections": [
      { "from": "width", "to": "rect", "to_param": "X Size" },
      { "from": "depth", "to": "rect", "to_param": "Y Size" },
      { "from": "rect", "from_param": "Rectangle", "to": "pop", "to_param": "Region" },
      { "from": "count", "to": "pop", "to_param": "Count" },
      { "from": "pop", "to": "voronoi", "to_param": "Points" },
      { "from": "rect", "from_param": "Rectangle", "to": "voronoi", "to_param": "Boundary" }
    ]
  }
}
